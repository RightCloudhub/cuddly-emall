# Mall environment example. Copy to .env and fill in.

# Database
MALL_DB_URL=jdbc:postgresql://postgres:5432/mall
MALL_DB_USER=mall
MALL_DB_PASSWORD=mall

# Redis
MALL_REDIS_URL=redis://redis:6379/1

# MinIO (shared with AskFlow, but mall uses prefix `mall/` inside the bucket)
MALL_MINIO_ENDPOINT=http://minio:9000
MALL_MINIO_ACCESS_KEY=minioadmin
MALL_MINIO_SECRET_KEY=minioadmin
MALL_MINIO_BUCKET=mall

# JWT — MUST equal AskFlow's SECRET_KEY (HS256 shared secret)
# Minimum 32 bytes (256 bits). Generate with: openssl rand -base64 48
MALL_JWT_SECRET=replace-with-shared-askflow-secret-at-least-32-bytes-long

# AskFlow integration (used from PR4 onwards)
MALL_ASKFLOW_BASE_URL=http://askflow:8000
MALL_ASKFLOW_SERVICE_TOKEN=
